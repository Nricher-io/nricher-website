# Copier ce fichier en .env (jamais commité, voir .gitignore) et remplir les vraies valeurs.
# Le token est par entreprise — genere depuis la page "APIs" de l'administration nricher
# (CompanySettings.companyApiTokenPlain). Ne jamais mettre de vraie valeur dans ce fichier
# .env.example, qui lui est versionne.

NRICHER_API_BASE_URL=https://api.nricher.io
NRICHER_API_TOKEN=

# Token JWT au niveau site (pas par entreprise), pour GET /v1/companies
# (liste des entreprises avec Weekly KPIs actif, utilisee par generate_index.py
# pour completer companies.json automatiquement). A generer cote nricher-workspace
# avec le JWT_ACCESS_TOKEN_SECRET de l'environnement cible et a transmettre en
# header Authorization: Bearer <token> — jamais en query param.
NRICHER_SITE_TOKEN=
