# Copier ce fichier en .env (jamais commité, voir .gitignore) et remplir les vraies valeurs.

NRICHER_API_BASE_URL=https://api.nricher.io

# Token JWT au niveau site (pas par entreprise). A generer cote nricher-workspace
# avec le JWT_ACCESS_TOKEN_SECRET de l'environnement cible, transmis en header
# Authorization: Bearer <token> — jamais en query param. Utilise par :
#   - generate_index.py  -> GET /v1/companies (liste des entreprises Weekly KPIs actif)
#   - generate_report.py -> POST /v1/:companyId/create-api-token (mint un token par
#     entreprise a la volee juste avant chaque generation, jamais stocke - le token
#     par entreprise est create-OU-ecrase cote serveur, donc fragile a mettre en cache)
NRICHER_SITE_TOKEN=
