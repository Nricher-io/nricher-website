# Copier ce fichier en .env (jamais commité, voir .gitignore) et remplir les vraies valeurs.
# Le token est par entreprise — genere depuis la page "APIs" de l'administration nricher
# (CompanySettings.companyApiTokenPlain). Ne jamais mettre de vraie valeur dans ce fichier
# .env.example, qui lui est versionne.

NRICHER_API_BASE_URL=https://api.nricher.io
NRICHER_API_TOKEN=
